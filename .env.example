JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-too

# Postgres passwords — used by k8s-secrets to create CNPG bootstrap secrets
POSTGRES_AUTH_PASS=change-this
POSTGRES_BLOG_PASS=change-this
POSTGRES_FEED_PASS=change-this

# Set to true and fill in credentials to send real emails.
# When false (default), OTP codes are printed to notify-service logs.
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@inkwell.app